<Window x:Class="BMPC.Views.AddSongDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BMPC.Views"
        xmlns:localControls="clr-namespace:BMPC.UserControls"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        mc:Ignorable="d"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Title="Add song to package"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Height="820"
        Width="900"
        Background="{DynamicResource MaterialDesign.Brush.Background}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="56" />
        </Grid.RowDefinitions>

        <!-- Main content area -->
        <Grid Margin="24">
            <Grid.ColumnDefinitions>
                <!-- Preview column -->
                <ColumnDefinition Width="260" />
                <!-- Form column -->
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- LEFT: artwork preview -->
            <StackPanel Grid.Column="0">
                <Border BorderBrush="{DynamicResource MaterialDesign.Brush.Separator.Background}"
                        BorderThickness="1"
                        Width="220"
                        Height="220"
                        HorizontalAlignment="Center"
                        CornerRadius="4">
                    <Border.Background>
                        <ImageBrush x:Name="ImgBrushIcon"
                                    ImageSource="{Binding PreviewImage}"
                                    Stretch="Uniform" />
                    </Border.Background>

                    <!-- overlay click target -->
                    <Border x:Name="AvatarBox">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsMouseOver, ElementName=AvatarBox}" Value="True">
                                        <Setter Property="Background" Value="#80000000" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>

                        <Button Height="220"
                                Width="220"
                                Background="Transparent"
                                BorderBrush="{x:Null}"
                                Command="{Binding SelectIconCommand}"
                                ToolTip="Select or change icon">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center" Orientation="Horizontal">
                                <materialDesign:PackIcon Kind="ImageEditOutline"
                                                         Width="32"
                                                         Height="32"
                                                         Foreground="White" />
                            </StackPanel>
                        </Button>
                    </Border>
                </Border>

                <TextBlock Text="Icon"
                           HorizontalAlignment="Center"
                           Margin="0,12,0,0"
                           FontSize="13"
                           Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
            </StackPanel>

            <!-- RIGHT: form -->
            <ScrollViewer Grid.Column="1"
                          Margin="24,0,0,0"
                          VerticalScrollBarVisibility="Auto">
                <StackPanel Orientation="Vertical"
                            Margin="0,0,8,0">

                    <!-- DETAILS CARD -->
                    <Border CornerRadius="4"
                            Padding="16"
                            Margin="0,0,0,16"
                            Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                            BorderBrush="{DynamicResource MaterialDesign.Brush.Separator.Background}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Details"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                            <TextBlock Text="Enter basic information about this track."
                                       FontSize="12"
                                       Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                                       Margin="0,4,0,16" />

                            <StackPanel Margin="0,0,0,0">
                                <TextBox Name="TxtName"
                                         Text="{Binding MusicName, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Name *"
                                         materialDesign:HintAssist.HelperText="Minimum 3 characters."
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                <!-- validation surface -->
                                <TextBlock Text="{Binding MusicNameError}"
                                           Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                           FontSize="12"
                                           Margin="4,4,0,0" />
                            </StackPanel>

                            <StackPanel Margin="0,16,0,0">
                                <TextBox Name="TxtDescription"
                                         Text="{Binding MusicDescription, UpdateSourceTrigger=PropertyChanged}"
                                         TextWrapping="Wrap"
                                         materialDesign:HintAssist.Hint="Description *"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                <TextBlock Text="{Binding MusicDescriptionError}"
                                           Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                           FontSize="12"
                                           Margin="4,4,0,0" />
                            </StackPanel>

                            <StackPanel Margin="0,16,0,0">
                                <TextBox Name="TxtAuthors"
                                         Text="{Binding MusicAuthors, UpdateSourceTrigger=PropertyChanged}"
                                         materialDesign:HintAssist.Hint="Authors *"
                                         Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                <TextBlock Text="{Binding MusicAuthorsError}"
                                           Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                           FontSize="12"
                                           Margin="4,4,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- SOURCE AUDIO CARD -->
                    <Border CornerRadius="4"
                            Padding="16"
                            Margin="0,0,0,16"
                            Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                            BorderBrush="{DynamicResource MaterialDesign.Brush.Separator.Background}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Chamber Music"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                            <TextBlock Text="Select audio files for your chamber."
                                       FontSize="12"
                                       Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                                       Margin="0,4,0,16" />

                            <!-- Base music -->
                            <StackPanel Margin="0,0,0,0">
                                <TextBlock Text="Base track *"
                                           FontWeight="SemiBold"
                                           FontSize="13" />
                                <DockPanel Margin="0,4,0,0"
                                           LastChildFill="True">
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal">
                                        <Button Margin="8,0,0,0"
                                                Style="{DynamicResource MaterialDesignFlatAccentButton}"
                                                Command="{Binding SelectSoundFileCommand}"
                                                CommandParameter="base"
                                                ToolTip="Select base audio file">
                                            Browse
                                        </Button>
                                    </StackPanel>

                                    <TextBox Name="TxtBaseFile"
                                             IsReadOnly="True"
                                             Text="{Binding BaseMusicFilePath, Mode=OneWay}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                </DockPanel>
                                <TextBlock Text="{Binding BaseMusicError}"
                                           Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                           FontSize="12"
                                           Margin="4,4,0,0" />
                            </StackPanel>

                            <StackPanel Margin="0,18,0,0">
                                <TextBlock Text="Base loop points"
                                           FontWeight="SemiBold"
                                           FontSize="13" />
                                <localControls:LoopPointsEditor x:Name="BaseLoopEditor"
                                                                Margin="0,6,0,0" />
                            </StackPanel>

                            <!-- Funnel music -->
                            <StackPanel Margin="0,24,0,0">
                                <TextBlock Text="Funnel track"
                                           FontWeight="SemiBold"
                                           FontSize="13" />
                                <DockPanel Margin="0,4,0,0"
                                           LastChildFill="True">
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal">
                                        <Button Margin="8,0,0,0"
                                                Style="{DynamicResource MaterialDesignFlatAccentButton}"
                                                Command="{Binding SelectSoundFileCommand}"
                                                CommandParameter="funnel"
                                                IsEnabled="{Binding CanSelectFunnelMusic}"
                                                ToolTip="Select funnel audio file">
                                            Browse
                                        </Button>
                                    </StackPanel>

                                    <TextBox Name="TxtFunnelFile"
                                             IsReadOnly="True"
                                             Text="{Binding FunnelMusicFilePath, Mode=OneWay}"
                                             IsEnabled="{Binding CanSelectFunnelMusic}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                </DockPanel>
                                <TextBlock Text="{Binding FunnelMusicError}"
                                           Foreground="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                           FontSize="12"
                                           Margin="4,4,0,0" />
                            </StackPanel>

                            <StackPanel Margin="0,18,0,0">
                                <TextBlock Text="Funnel loop points"
                                           FontWeight="SemiBold"
                                           FontSize="13" />
                                <localControls:LoopPointsEditor x:Name="FunnelLoopEditor"
                                                                Margin="0,6,0,0" />
                            </StackPanel>

                            <!-- Funnel options -->
                            <GroupBox Header="Funnel options"
                                      Margin="0,24,0,0"
                                      BorderBrush="{DynamicResource MaterialDesign.Brush.Separator.Background}"
                                      BorderThickness="1"
                                      Padding="12"
                                      FontSize="13">
                                <StackPanel>
                                    <CheckBox IsChecked="{Binding ApplyDefaultFunnelMusic}"
                                              IsEnabled="{Binding CanApplyDefaultFunnelMusic}"
                                              Margin="0,0,0,8">
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Use default funnel music" />
                                            <TextBlock Text="Automatically insert the default funnel track"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                                        </StackPanel>
                                    </CheckBox>

                                    <CheckBox IsChecked="{Binding SyncFunnelMusic}"
                                              IsEnabled="{Binding CanSelectFunnelSync}">
                                        <StackPanel Orientation="Vertical">
                                            <TextBlock Text="Sync funnel music to base" />
                                            <TextBlock Text="Align funnel timing with the base track"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                                        </StackPanel>
                                    </CheckBox>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </Border>

                    <!-- GEL SFX CARD -->
                    <Border CornerRadius="4"
                            Padding="16"
                            Margin="0,0,0,16"
                            Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                            BorderBrush="{DynamicResource MaterialDesign.Brush.Separator.Background}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="Gel SFX"
                                       FontWeight="Bold"
                                       FontSize="16"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                            <TextBlock Text="Select gel SFX for this track. (optional)"
                                       FontSize="12"
                                       Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                                       Margin="0,4,0,16" />

                            <!-- Speed Gel -->
                            <StackPanel Margin="0,0,0,16">
                                <TextBlock Text="Speed gel SFX"
                                           FontWeight="SemiBold"
                                           FontSize="13" />
                                <DockPanel Margin="0,4,0,0"
                                           LastChildFill="True">
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal">
                                        <Button Margin="8,0,0,0"
                                                Style="{DynamicResource MaterialDesignFlatAccentButton}"
                                                Command="{Binding SelectSfxCommand}"
                                                CommandParameter="speed">
                                            Browse
                                        </Button>
                                        <Button Margin="8,0,0,0"
                                                Style="{DynamicResource MaterialDesignFlatAccentButton}"
                                                Command="{Binding ClearSfxCommand}"
                                                CommandParameter="speed"
                                                IsEnabled="{Binding HasSelectedSpeedGel}">
                                            Clear
                                        </Button>
                                    </StackPanel>

                                    <TextBox IsReadOnly="True"
                                             Text="{Binding SpeedGelSelections, Mode=OneWay}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                </DockPanel>
                            </StackPanel>

                            <!-- Bounce Gel -->
                            <StackPanel>
                                <TextBlock Text="Bounce gel SFX"
                                           FontWeight="SemiBold"
                                           FontSize="13" />
                                <DockPanel Margin="0,4,0,0"
                                           LastChildFill="True">
                                    <StackPanel DockPanel.Dock="Right"
                                                Orientation="Horizontal">
                                        <Button Margin="8,0,0,0"
                                                Style="{DynamicResource MaterialDesignFlatAccentButton}"
                                                Command="{Binding SelectSfxCommand}"
                                                CommandParameter="bounce">
                                            Browse
                                        </Button>
                                        <Button Margin="8,0,0,0"
                                                Style="{DynamicResource MaterialDesignFlatAccentButton}"
                                                Command="{Binding ClearSfxCommand}"
                                                CommandParameter="bounce"
                                                IsEnabled="{Binding HasSelectedBounceGel}">
                                            Clear
                                        </Button>
                                    </StackPanel>

                                    <TextBox IsReadOnly="True"
                                             Text="{Binding BounceGelSelections, Mode=OneWay}"
                                             Style="{StaticResource MaterialDesignFloatingHintTextBox}" />
                                </DockPanel>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>
        </Grid>

        <!-- FOOTER -->
        <Border Grid.Row="1"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                Padding="10,0"
                VerticalAlignment="Stretch">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Margin="0,0,0,0">

                <Button Style="{DynamicResource MaterialDesignFlatDarkBgButton}"
                        Padding="12,4"
                        Margin="0,0,12,0"
                        Command="{Binding AddCommand}">
                    <StackPanel Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <materialDesign:PackIcon Margin="0,0,6,0"
                                                 Kind="PlusBold"/>
                        <TextBlock Text="Add"/>
                    </StackPanel>
                </Button>

                <Button Style="{DynamicResource MaterialDesignFlatAccentButton}"
                        Command="{Binding CancelCommand}">
                    Cancel
                </Button>
            </StackPanel>
        </Grid>
        </Border>
    </Grid>
</Window>
