<Window x:Class="BMPC.Views.Main"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BMPC.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" xmlns:viewmodels="clr-namespace:BMPC.ViewModels" d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        mc:Ignorable="d"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Title="BEEmod Music Package Creator"
        Width="1200"
        Height="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        PreviewMouseDown="Window_PreviewMouseDown"
        Background="{DynamicResource MaterialDesign.Brush.Background}">

    <Window.InputBindings>
        <KeyBinding Modifiers="Control"
                    Key="N"
                    Command="{Binding CreateNewPackageCommand}" />
    </Window.InputBindings>

    <Grid>
        <Grid.RowDefinitions>
            <!-- App header -->
            <RowDefinition Height="Auto" />
            <!-- Main body -->
            <RowDefinition Height="*" />
            <!-- Info bar -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- TOP APP BAR -->
        <Border Grid.Row="0"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                BorderBrush="{DynamicResource MaterialDesign.Brush.Separator.Background}"
                BorderThickness="0,0,0,1"
                Padding="16,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Brand / version -->
                <StackPanel Grid.Column="0"
                            Orientation="Vertical"
                            VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="BMPC"
                                   FontSize="16"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                        <TextBlock Text="{Binding AppVersion}"
                                   FontSize="16"
                                   Margin="4,0,0,0" />
                    </StackPanel>
                    <TextBlock Text="Created by aerond"
                               FontSize="11"
                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}" />
                </StackPanel>

                <!-- External links / settings -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right"
                            Margin="0,0,0,0">
                    <Button Style="{DynamicResource MaterialDesignFlatAccentButton}"
                            Click="GitHubButton_Click"
                            Margin="0,0,8,0"
                            ToolTip="aerond7/beemod-music-package-creator">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="GitHub" />
                        </StackPanel>
                    </Button>

                    <Button Style="{DynamicResource MaterialDesignFlatAccentButton}"
                            Click="WebsiteButton_Click" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Website" />
                        </StackPanel>
                    </Button>

                    <Button Style="{DynamicResource MaterialDesignFlatAccentButton}"
                            Click="DiscordButton_Click" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="Discord" />
                        </StackPanel>
                    </Button>

                    <Button Style="{DynamicResource MaterialDesignFlatDarkBgButton}"
                            Click="SettingsButton_Click"
                            Padding="10,4"
                            Margin="0,0,0,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <materialDesign:PackIcon Margin="0,0,6,0" Kind="CogOutline" />
                            <TextBlock Text="Settings" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- MAIN BODY -->
        <Grid Grid.Row="1" Margin="24,16,24,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Card containing the packages list and actions -->
            <Border Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                    BorderBrush="{DynamicResource MaterialDesign.Brush.Separator.Background}"
                    BorderThickness="1"
                    CornerRadius="4"
                    Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <!-- Header row with title, total counter, actions -->
                        <RowDefinition Height="Auto" />
                        <!-- Divider -->
                        <RowDefinition Height="Auto" />
                        <!-- Packages list -->
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- HEADER TOOLBAR -->
                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <!-- Title and count -->
                        <StackPanel Grid.Column="0"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    Margin="0,0,8,0">
                            <TextBlock Text="Packages"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Foreground="{DynamicResource MaterialDesign.Brush.Primary}" />
                            <TextBlock Text="{Binding TotalPackages, StringFormat={}({0})}"
                                       FontSize="18"
                                       FontWeight="Bold"
                                       Margin="8,0,0,0" />
                        </StackPanel>

                        <!-- Search / filter -->
                        <TextBox Grid.Column="1"
                                 Name="TxtSearch"
                                 VerticalAlignment="Center"
                                 Margin="8,0,8,0"
                                 MinWidth="180"
                                 TextChanged="TxtSearch_TextChanged"
                                 materialDesign:HintAssist.Hint="Search packages..."
                                 materialDesign:TextFieldAssist.HasClearButton="True"
                                 Style="{DynamicResource MaterialDesignTextBox}" />

                        <!-- Row actions -->
                        <StackPanel Grid.Column="2"
                                    Orientation="Horizontal"
                                    VerticalAlignment="Center"
                                    HorizontalAlignment="Right">

                            <!-- Remove button bound to LV selection -->
                            <Button Name="BtnPackageRemove"
                                    Style="{DynamicResource MaterialDesignFlatDarkBgButton}"
                                    Command="{Binding DeletePackageCommand}"
                                    CommandParameter="{Binding ElementName=LvPackages,Path=SelectedItem}"
                                    Padding="10,4"
                                    Margin="0,0,8,0"
                                    Background="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                    BorderBrush="{DynamicResource MaterialDesign.Brush.ValidationError}"
                                    Foreground="White">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <materialDesign:PackIcon Margin="0,0,6,0"
                                                             Kind="TrashCan" />
                                    <TextBlock Text="Remove" />
                                </StackPanel>
                            </Button>

                            <!-- Edit button bound to LV selection -->
                            <Button Name="BtnPackageEdit"
                                    Style="{DynamicResource MaterialDesignFlatDarkBgButton}"
                                    Command="{Binding EditPackageCommand}"
                                    CommandParameter="{Binding ElementName=LvPackages,Path=SelectedItem}"
                                    Padding="10,4"
                                    Margin="0,0,8,0">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <materialDesign:PackIcon Margin="0,0,6,0"
                                                             Kind="Pencil" />
                                    <TextBlock Text="Edit" />
                                </StackPanel>
                            </Button>

                            <!-- Create button is primary action -->
                            <Button Style="{DynamicResource MaterialDesignFlatDarkBgButton}"
                                    Command="{Binding CreateNewPackageCommand}"
                                    Padding="10,4">
                                <StackPanel Orientation="Horizontal"
                                            VerticalAlignment="Center">
                                    <materialDesign:PackIcon Margin="0,0,6,0"
                                                             Kind="PlusBold" />
                                    <TextBlock Text="New package" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>

                    <!-- Divider -->
                    <Separator Grid.Row="1"
                               Margin="0,12,0,12"
                               Background="{DynamicResource MaterialDesign.Brush.Separator.Background}" />

                    <!-- LIST AREA -->
                    <Grid Grid.Row="2">
                        <ListView Name="LvPackages"
                                  ItemsSource="{Binding Packages}"
                                  SelectionMode="Single"
                                  PreviewMouseDown="LvPackages_PreviewMouseDown"
                                  MouseDoubleClick="LvPackages_MouseDoubleClick"
                                  GridViewColumnHeader.Click="LvPackages_ColumnHeaderClick"
                                  BorderThickness="0">
                            <ListView.InputBindings>
                                <KeyBinding Key="Return"
                                            Command="{Binding EditPackageCommand}"
                                            CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListView}}" />
                                <KeyBinding Key="F2"
                                            Command="{Binding EditPackageCommand}"
                                            CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListView}}" />
                                <KeyBinding Key="Delete"
                                            Command="{Binding DeletePackageCommand}"
                                            CommandParameter="{Binding SelectedItem, RelativeSource={RelativeSource AncestorType=ListView}}" />
                            </ListView.InputBindings>
                            <ListView.ContextMenu>
                                <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                    <MenuItem Header="New package"
                                              Command="{Binding CreateNewPackageCommand}">
                                        <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="PlusBold" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="Edit"
                                              Command="{Binding EditPackageCommand}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="Pencil" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <MenuItem Header="Remove"
                                              Command="{Binding DeletePackageCommand}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="TrashCan" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                    <Separator />
                                    <MenuItem Header="Open package location"
                                              Command="{Binding OpenPackageLocationCommand}"
                                              CommandParameter="{Binding PlacementTarget.SelectedItem, RelativeSource={RelativeSource AncestorType=ContextMenu}}">
                                        <MenuItem.Icon>
                                            <materialDesign:PackIcon Kind="FolderOpenOutline" />
                                        </MenuItem.Icon>
                                    </MenuItem>
                                </ContextMenu>
                            </ListView.ContextMenu>
                            <ListView.View>
                                <GridView AllowsColumnReorder="False">
                                    <GridView.ColumnHeaderContainerStyle>
                                        <Style TargetType="GridViewColumnHeader"
                                               BasedOn="{StaticResource {x:Type GridViewColumnHeader}}">
                                            <Setter Property="HorizontalContentAlignment" Value="Left" />
                                            <Setter Property="Padding" Value="6,4,0,10" />
                                        </Style>
                                    </GridView.ColumnHeaderContainerStyle>
                                    <GridViewColumn x:Name="ColName"
                                                    Header="Name"
                                                    Width="500">
                                        <GridViewColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding Name}"
                                                           ToolTip="{Binding Description}" />
                                            </DataTemplate>
                                        </GridViewColumn.CellTemplate>
                                    </GridViewColumn>
                                    <GridViewColumn x:Name="ColSongs"
                                                    Header="Songs in package"
                                                    DisplayMemberBinding="{Binding SongCount}"
                                                    Width="200"/>
                                    <GridViewColumn x:Name="ColAdded"
                                                    Header="Added"
                                                    DisplayMemberBinding="{Binding Added}"
                                                    Width="300"/>
                                </GridView>
                            </ListView.View>
                        </ListView>

                        <!-- Empty state -->
                        <TextBlock Text="No packages yet - click &quot;New package&quot; to create one."
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False"
                                   FontSize="14"
                                   Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding TotalPackages}" Value="0">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Grid>
            </Border>
        </Grid>

        <!-- INFO BAR / COPYRIGHT WARNING -->
        <Border Grid.Row="2"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                BorderBrush="{DynamicResource MaterialDesign.Brush.Separator.Background}"
                BorderThickness="1,1,1,0"
                Padding="16">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <materialDesign:PackIcon Kind="InformationOutline"
                                         Width="20"
                                         Height="20"
                                         Margin="0,0,8,0"
                                         Foreground="{DynamicResource BmpcWarningBrush}" />
                <TextBlock Text="Respect copyright. Use only music you own, music that is free to use, or music you have permission to use."
                           Foreground="{DynamicResource BmpcWarningBrush}"
                           FontSize="13"
                           TextWrapping="Wrap"
                           Margin="0,2,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
