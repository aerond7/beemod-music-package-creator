<Window x:Class="BMPC.Views.SettingsView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Settings"
        Width="520"
        Height="330"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        Background="{DynamicResource MaterialDesign.Brush.Background}">

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="General" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" />

            <DockPanel Margin="0,0,0,12">
                <TextBlock Text="After import" VerticalAlignment="Center" Width="180"/>
                <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding SelectedPostImportAction}">
                    <ComboBoxItem Tag="Ask">Ask to open BEEmod</ComboBoxItem>
                    <ComboBoxItem Tag="OpenBeemod">Open BEEmod automatically</ComboBoxItem>
                    <ComboBoxItem Tag="DoNothing">Do nothing</ComboBoxItem>
                </ComboBox>
            </DockPanel>

            <DockPanel Margin="0,0,0,12">
                <TextBlock Text="Confirm before delete" VerticalAlignment="Center" Width="180"/>
                <ToggleButton IsChecked="{Binding ConfirmBeforeDelete}"
                              Style="{StaticResource MaterialDesignSwitchToggleButton}"
                              HorizontalAlignment="Left"/>
            </DockPanel>

            <DockPanel>
                <TextBlock Text="Theme" VerticalAlignment="Center" Width="180"/>
                <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding SelectedThemeMode}">
                    <ComboBoxItem Tag="Auto">Auto</ComboBoxItem>
                    <ComboBoxItem Tag="Light">Light</ComboBoxItem>
                    <ComboBoxItem Tag="Dark">Dark</ComboBoxItem>
                </ComboBox>
            </DockPanel>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Margin="0,0,8,0" Style="{DynamicResource MaterialDesignFlatDarkBgButton}" Click="Save_Click">Save</Button>
            <Button Style="{DynamicResource MaterialDesignFlatButton}" Click="Cancel_Click">Cancel</Button>
        </StackPanel>
    </Grid>
</Window>


