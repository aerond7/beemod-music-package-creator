<Window x:Class="BMPC.Views.CreatePackageView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:BMPC.Views"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:usercontrols="clr-namespace:BMPC.UserControls"
        xmlns:converters="clr-namespace:BMPC.Converters"
        mc:Ignorable="d"
        TextElement.FontWeight="Medium"
        TextElement.FontSize="14"
        FontFamily="{materialDesign:MaterialDesignFont}"
        Title="{Binding WindowTitle}"
        Height="650"
        Width="800"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanMinimize"
        Background="{DynamicResource MaterialDesign.Brush.Background}">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <converters:BooleanToValueConverter x:Key="BoolToVal" DesiredValue="20" />
        <converters:InverseImportVisibleToVisibilityConverter x:Key="HideNextWhenImportVisible" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <!-- Main card -->
            <RowDefinition Height="*" />
            <!-- Footer -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- MAIN CARD -->
        <Border Grid.Row="0"
                Margin="24,24,24,16"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                BorderBrush="{DynamicResource MaterialDesign.Brush.Separator.Background}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- header: stage title + desc -->
                    <RowDefinition Height="Auto" />
                    <!-- divider -->
                    <RowDefinition Height="Auto" />
                    <!-- body: current step content -->
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- HEADER -->
                <StackPanel Grid.Row="0"
                            Orientation="Vertical">
                    <TextBlock Text="{Binding CurrentStageName}"
                               FontSize="20"
                               FontWeight="Bold"
                               Foreground="{DynamicResource MaterialDesign.Brush.Primary}"
                               TextWrapping="Wrap" />
                    <TextBlock Text="{Binding CurrentStageDescription}"
                               Margin="0,4,0,0"
                               FontSize="13"
                               Foreground="{DynamicResource MaterialDesign.Brush.ForegroundLight}"
                               TextWrapping="Wrap" />
                </StackPanel>

                <!-- DIVIDER -->
                <Separator Grid.Row="1"
                           Margin="0,16,0,16"
                           Background="{DynamicResource MaterialDesign.Brush.Separator.Background}" />

                <!-- BODY -->
                <Border Grid.Row="2"
                        Background="{DynamicResource MaterialDesign.Brush.Background}"
                        BorderBrush="{DynamicResource MaterialDesign.Brush.Separator.Background}"
                        BorderThickness="1"
                        CornerRadius="4"
                        Padding="16">
                    <!-- ScrollViewer so large steps don't blow the window -->
                    <ContentControl Content="{Binding CurrentSetupControl}" />
                </Border>
            </Grid>
        </Border>

        <!-- FOOTER BAR -->
        <Border Grid.Row="1"
                Background="{DynamicResource MaterialDesign.Brush.Card.Background}"
                BorderBrush="{DynamicResource MaterialDesign.Brush.Separator.Background}"
                BorderThickness="1,1,1,0"
                Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- LEFT STATUS: spinner + summary -->
                <StackPanel Grid.Column="0"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">

                    <!-- activity spinner -->
                    <ProgressBar Width="{Binding Path=SpinnerVisible, Converter={StaticResource BoolToVal}}"
                                 Height="20"
                                 Margin="0,0,12,0"
                                 IsIndeterminate="True"
                                 Style="{StaticResource MaterialDesignCircularProgressBar}"
                                 Value="0" />

                    <!-- stage summary text -->
                    <TextBlock FontSize="14"
                               Text="{Binding StageSummary}"
                               VerticalAlignment="Center"
                               TextWrapping="Wrap" />
                </StackPanel>

                <!-- RIGHT ACTIONS -->
                <StackPanel Grid.Column="1"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Right">
                    <!-- BACK (only visible if CanBacktrack) -->
                    <Button Style="{DynamicResource MaterialDesignFlatAccentButton}"
                            Padding="10,4" Margin="0,0,8,0"
                            Command="{Binding BackCommand}"
                            Visibility="{Binding Path=CanBacktrack, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <materialDesign:PackIcon Margin="0,0,6,0"
                                                     Kind="ArrowLeftBold"/>
                            <TextBlock Text="Back"/>
                        </StackPanel>
                    </Button>

                    <!-- NEXT (visible during wizard steps) -->
                    <Button Style="{DynamicResource MaterialDesignFlatDarkBgButton}"
                            Padding="12,4" Margin="0,0,8,0"
                            Command="{Binding NextCommand}">
                        <Button.Visibility>
                            <MultiBinding Converter="{StaticResource HideNextWhenImportVisible}">
                                <Binding Path="ButtonsVisible"/>
                                <Binding Path="IsImportVisible"/>
                            </MultiBinding>
                        </Button.Visibility>
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <TextBlock Text="Next"/>
                            <materialDesign:PackIcon Margin="6,0,0,0" Kind="ArrowRightBold"/>
                        </StackPanel>
                    </Button>

                    <!-- CREATE / IMPORT (final step only) -->
                    <Button Style="{DynamicResource MaterialDesignFlatDarkBgButton}"
                            Padding="12,4" Margin="0,0,8,0"
                            Command="{Binding ImportPackageCommand}"
                            Visibility="{Binding Path=IsImportVisible, Converter={StaticResource BoolToVis}}">
                        <StackPanel Orientation="Horizontal"
                                    VerticalAlignment="Center">
                            <materialDesign:PackIcon Margin="0,0,6,0"
                                                     Kind="Import"/>
                            <TextBlock Text="{Binding ImportButtonLabel}"/>
                        </StackPanel>
                    </Button>

                    <!-- CANCEL (always available while editable) -->
                    <Button Style="{DynamicResource MaterialDesignFlatAccentButton}"
                            Padding="10,4"
                            Command="{Binding CancelCommand}"
                            Visibility="{Binding Path=ButtonsVisible, Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="Cancel"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
