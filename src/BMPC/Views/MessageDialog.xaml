<Window x:Class="BMPC.Views.MessageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="Dialog"
        Width="420"
        SizeToContent="Height"
        MinHeight="170"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource MaterialDesign.Brush.Background}">

    <Border Background="{DynamicResource MaterialDesign.Brush.Background}"
            Padding="18,16,18,16">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Width="38"
                        Height="38"
                        CornerRadius="19"
                        Background="{Binding IconBackground}">
                    <materialDesign:PackIcon x:Name="DialogIcon"
                                             Width="23"
                                             Height="23"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Foreground="White" />
                </Border>

                <ScrollViewer Grid.Column="1"
                          Margin="14,1,0,0"
                          MaxHeight="260"
                          VerticalScrollBarVisibility="Auto">
                    <TextBlock Text="{Binding Message}"
                               FontSize="13"
                               LineHeight="19"
                               TextWrapping="Wrap"
                               Foreground="{DynamicResource MaterialDesign.Brush.Foreground}" />
                </ScrollViewer>
            </Grid>

            <StackPanel Grid.Row="1"
                        Margin="0,16,0,0"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="YesButton"
                        MinWidth="76"
                        Margin="0,0,8,0"
                        Style="{DynamicResource MaterialDesignFlatDarkBgButton}"
                        Click="YesButton_Click">
                    Yes
                </Button>
                <Button x:Name="NoButton"
                        MinWidth="76"
                        Margin="0,0,8,0"
                        Style="{DynamicResource MaterialDesignFlatButton}"
                        Click="NoButton_Click">
                    No
                </Button>
                <Button x:Name="OkButton"
                        MinWidth="76"
                        Style="{DynamicResource MaterialDesignFlatDarkBgButton}"
                        Click="OkButton_Click">
                    OK
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
