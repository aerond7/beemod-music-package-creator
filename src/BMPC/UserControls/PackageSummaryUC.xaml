<UserControl x:Class="BMPC.UserControls.PackageSummaryUC"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:BMPC.UserControls"
             mc:Ignorable="d" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             xmlns:interactivity="http://schemas.microsoft.com/xaml/behaviors"
             TextElement.FontWeight="Medium"
             TextElement.FontSize="14"
             FontFamily="{materialDesign:MaterialDesignFont}"
             d:DesignHeight="580" d:DesignWidth="800">

    <Grid Margin="50,50,50,50">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Orientation="Vertical" HorizontalAlignment="Right">
            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <Label HorizontalAlignment="Right" FontWeight="Bold">Package name:</Label>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <Label HorizontalAlignment="Right" FontWeight="Bold">Package description:</Label>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <Label HorizontalAlignment="Right" FontWeight="Bold">Group name:</Label>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <Label HorizontalAlignment="Right" FontWeight="Bold">Songs:</Label>
            </StackPanel>
        </StackPanel>

        <StackPanel Grid.Column="1" Orientation="Vertical" HorizontalAlignment="Left">
            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <Label FontWeight="Light">
                    <TextBlock Text="{Binding SummaryPackName}" TextTrimming="CharacterEllipsis"></TextBlock>
                </Label>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <Label FontWeight="Light">
                    <TextBlock Text="{Binding SummaryPackDescription}" TextTrimming="WordEllipsis"></TextBlock>
                </Label>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <Label FontWeight="Light">
                    <TextBlock Text="{Binding SummaryPackGroupName}" TextTrimming="CharacterEllipsis"></TextBlock>
                </Label>
            </StackPanel>

            <StackPanel Orientation="Vertical" Margin="0,10,0,0">
                <Label FontWeight="Light">
                    <TextBlock Text="{Binding SummaryPackSongs}"></TextBlock>
                </Label>
            </StackPanel>
        </StackPanel>
    </Grid>

</UserControl>
